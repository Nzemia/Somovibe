generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}




enum Role {
  ADMIN
  TEACHER
  STUDENT
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  phone     String?  @unique
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())

  teacherProfile  TeacherProfile?
  pdfs            Pdf[]
  wallets         Wallet[]
  purchases       Purchase[]
  pendingPayments PendingPayment[]
  downloads       Download[]
  materialViews   MaterialView[]
}

model TeacherProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum PaymentType {
  TEACHER_VERIFICATION
  PDF_PURCHASE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

model PendingPayment {
  id            String        @id @default(uuid())
  userId        String
  phone         String
  amount        Int
  type          PaymentType
  status        PaymentStatus @default(PENDING)
  referenceCode String        @unique
  metadata      String?       // JSON string for additional data like pdfId
  createdAt     DateTime      @default(now())
  completedAt   DateTime?

  user User @relation(fields: [userId], references: [id])
}

enum PdfStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MaterialType {
  PDF
  PDF_SLIDES
  POWERPOINT
  CLASS_INSTRUCTIONS
  SCHEME_OF_WORK
  LESSON_PLAN
  EXAM_QUIZ
}

model Pdf {
  id           String       @id @default(uuid())
  title        String
  description  String
  subject      String
  grade        String
  price        Int
  fileUrl      String
  materialType MaterialType @default(PDF)
  status       PdfStatus    @default(PENDING)
  teacherId    String
  createdAt    DateTime     @default(now())

  teacher User @relation(fields: [teacherId], references: [id])

  purchases     Purchase[]
  downloads     Download[]
  materialViews MaterialView[]
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  walletTransactions WalletTransaction[]
}

model WalletTransaction {
  id        String   @id @default(uuid())
  walletId  String
  amount    Int
  type      String   // credit | debit
  createdAt DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])
}

model Purchase {
  id        String   @id @default(uuid())
  userId    String
  pdfId     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  pdf  Pdf  @relation(fields: [pdfId], references: [id])

  @@unique([userId, pdfId])
}

model Download {
  id        String   @id @default(uuid())
  userId    String
  pdfId     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  pdf  Pdf  @relation(fields: [pdfId], references: [id])

  @@index([userId, pdfId])
  @@index([pdfId])
}

model MaterialView {
  id        String   @id @default(uuid())
  userId    String?  // Nullable for anonymous views
  pdfId     String
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
  pdf  Pdf   @relation(fields: [pdfId], references: [id])

  @@index([pdfId])
  @@index([userId])
}
