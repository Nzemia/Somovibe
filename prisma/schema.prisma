
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum Role {
  ADMIN
  TEACHER
  STUDENT
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // For credentials login
  phone         String?   @unique
  role          Role      @default(STUDENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt @default(now())

  accounts        Account[]
  sessions        Session[]
  teacherProfile  TeacherProfile?
  pdfs            Pdf[]
  wallets         Wallet[]
  purchases       Purchase[]
  pendingPayments PendingPayment[]
  downloads       Download[]
  materialViews   MaterialView[]
  reviews         Review[]
  withdrawalRequests WithdrawalRequest[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model TeacherProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum PaymentType {
  TEACHER_VERIFICATION
  PDF_PURCHASE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

model PendingPayment {
  id            String        @id @default(uuid())
  userId        String
  phone         String
  amount        Int
  type          PaymentType
  status        PaymentStatus @default(PENDING)
  referenceCode String        @unique
  metadata      String?       // JSON string for additional data like pdfId
  createdAt     DateTime      @default(now())
  completedAt   DateTime?

  user User @relation(fields: [userId], references: [id])
}

enum PdfStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MaterialType {
  PDF
  PDF_SLIDES
  POWERPOINT
  CLASS_INSTRUCTIONS
  SCHEME_OF_WORK
  LESSON_PLAN
  EXAM_QUIZ
}

model Pdf {
  id           String       @id @default(uuid())
  title        String
  description  String
  subject      String
  grade        String
  price        Int
  fileUrl      String
  thumbnailUrl String?
  materialType MaterialType @default(PDF)
  status       PdfStatus    @default(PENDING)
  teacherId    String
  createdAt    DateTime     @default(now())

  teacher User @relation(fields: [teacherId], references: [id])

  purchases     Purchase[]
  downloads     Download[]
  materialViews MaterialView[]
  reviews       Review[]
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  walletTransactions WalletTransaction[]
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

model WalletTransaction {
  id        String          @id @default(uuid())
  walletId  String
  amount    Int
  type      TransactionType
  createdAt DateTime        @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])
}

model WithdrawalRequest {
  id                String           @id @default(uuid())
  userId            String
  amount            Int
  phone             String
  status            WithdrawalStatus @default(PENDING)
  mpesaReceiptNumber String?
  mpesaConversationId String?
  mpesaResponseCode  String?
  failureReason     String?
  createdAt         DateTime         @default(now())
  completedAt       DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model Purchase {
  id        String   @id @default(uuid())
  userId    String
  pdfId     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  pdf  Pdf  @relation(fields: [pdfId], references: [id])

  @@unique([userId, pdfId])
}

model Download {
  id        String   @id @default(uuid())
  userId    String
  pdfId     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  pdf  Pdf  @relation(fields: [pdfId], references: [id])

  @@index([userId, pdfId])
  @@index([pdfId])
}

model MaterialView {
  id        String   @id @default(uuid())
  userId    String?  // Nullable for anonymous views
  pdfId     String
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
  pdf  Pdf   @relation(fields: [pdfId], references: [id])

  @@index([pdfId])
  @@index([userId])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  pdfId     String
  rating    Int      // 1-5 stars
  comment   String?
  reply     String?  // Teacher's reply to the review
  repliedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  pdf  Pdf  @relation(fields: [pdfId], references: [id])

  @@unique([userId, pdfId]) // One review per user per material
  @@index([pdfId])
}

