# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Cloudinary
CLOUDINARY_NAME=""
CLOUDINARY_API=""
CLOUDINARY_API_SECRET=""

# OAuth Providers
# Google: https://console.cloud.google.com/apis/credentials
# GitHub: https://github.com/settings/developers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# M-Pesa
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_SHORTCODE=""
MPESA_PASSKEY=""
MPESA_ENVIRONMENT="production"

# M-Pesa B2C - For withdrawals
MPESA_B2C_SHORTCODE=""
MPESA_INITIATOR_NAME=""
MPESA_SECURITY_CREDENTIAL=""

# Callback URLs
MPESA_CALLBACK_URL="https://your-domain.com"
NEXT_PUBLIC_BASE_URL="https://your-domain.com"

# Development mode - set to "true" to bypass M-Pesa payments (for testing only)
DEV_MODE="false"
NEXT_PUBLIC_DEV_MODE="false"

# Platform Admin Email (user with this email gets admin role)
PLATFORM_ADMIN_ID="admin@your-domain.com"

# Resend (Email)
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
